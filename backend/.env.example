# UltraEdge AIPC Studio — Backend Configuration
# Copy to .env and adjust as needed.  All values below are the defaults.

# ── Paths ──────────────────────────────────────────────────────────────────
# ULTRAEEDGE_PROJECT_ROOT=/path/to/UltraEdge-AIPC-Studio
# ULTRAEEDGE_MODELS_DIR=/path/to/UltraEdge-AIPC-Studio/models
# ULTRAEEDGE_APP_DATA_DIR=/path/to/UltraEdge-AIPC-Studio/backend/app_data
# ULTRAEEDGE_OV_CACHE_DIR=/path/to/UltraEdge-AIPC-Studio/backend/app_data/ov_cache

# ── Server ─────────────────────────────────────────────────────────────────
ULTRAEEDGE_HOST=127.0.0.1
ULTRAEEDGE_PORT=8000
ULTRAEEDGE_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
ULTRAEEDGE_RELOAD=true

# ── Feature flags ──────────────────────────────────────────────────────────
ULTRAEEDGE_LOG_LEVEL=INFO

# Dangerous local developer capability. Leave false unless explicitly needed.
ULTRAEEDGE_ENABLE_CODE_EXECUTION=false

# Omni latency tuning: use rk4 for slower, higher-order token2wav integration.
ULTRAEEDGE_TOKEN2WAV_SOLVER=euler
ULTRAEEDGE_TOKEN2WAV_ODE_STEPS=10
ULTRAEEDGE_TOKEN2WAV_FAST_ODE_STEPS=8
ULTRAEEDGE_OMNI_FAST_MAX_NEW_TOKENS=96
ULTRAEEDGE_TTS_BALANCED_MAX_THINKER_TOKENS=256
ULTRAEEDGE_TTS_FAST_MAX_TALKER_TOKENS=768
ULTRAEEDGE_TTS_BALANCED_MAX_TALKER_TOKENS=1536
